{
  "ConnectionStrings": {
    "WasteManagement": "Server=(localdb)\\MSSQLLocalDB;Database=WasteManagement;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "GeminiSettings": {
    "BaseUrl": "",
    "MunicipalityNo": "",
    "SubscriptionKey": ""
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/import-worker-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "shared": true
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
